# ---------- Clerk ----------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ---------- OpenAI ----------
OPENAI_API_KEY=sk-proj-xxx
OPENAI_MODEL=gpt-4o
# Opcional: overrides por modo de scan
# OPENAI_SCAN_MODEL=gpt-4o
# OPENAI_SCAN_MODEL_SMC=gpt-4o
# OPENAI_SCAN_MODEL_CLASSICO=gpt-4o

# ---------- Stripe ----------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PRICE_ID=price_xxx
STRIPE_MOCK=true

# ---------- Market data ----------
# Twelve Data (forex) — plano Basic gratuito: 800 req/dia, 8 símbolos WS
# https://twelvedata.com/pricing
TWELVEDATA_API_KEY=
# Binance (cripto) — público, sem chave necessária

# ---------- Cron ----------
# Vercel injeta CRON_SECRET automaticamente quando você usa Vercel Cron.
# Em dev local, defina manualmente se quiser proteger /api/cron/scan-all:
CRON_SECRET=

# ---------- Database (Prisma + Postgres / Supabase) ----------
DATABASE_URL="postgresql://user:password@localhost:5432/tradevision"
